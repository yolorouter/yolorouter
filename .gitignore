# internal/web/dist holds the go:embed source for the frontend. Real build
# output (regenerated by scripts/dev.sh from frontend/dist/) must never be
# committed, but the minimal placeholder index.html must always stay
# tracked — a clean clone needs it present to compile at all (design doc §7).
internal/web/dist/*
!internal/web/dist/index.html